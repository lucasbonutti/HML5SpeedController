{
  "name": "hml5-speed-controller",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "format": "prettier --ignore-unknown --write .gitignore README.md package.json package-lock.json build.mjs \"src/**/*.{js,txt}\" \"tests/**/*.{mjs,html}\"",
    "format:check": "prettier --ignore-unknown --check .gitignore README.md package.json package-lock.json build.mjs \"src/**/*.{js,txt}\" \"tests/**/*.{mjs,html}\"",
    "validate": "node tests/validate.mjs",
    "test:runtime": "node tests/runtime.mjs",
    "test": "npm run build && npm run validate && npm run test:runtime",
    "test:youtube": "node tests/youtube-live.mjs"
  },
  "devDependencies": {
    "prettier": "^3.1.0",
    "puppeteer": "^24.10.2"
  }
}
